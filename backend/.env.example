# =============================================================================
# MGNREGA Verification & Fraud Intelligence System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# -----------------------------------------------------------------------------
# Database Configuration (PostGIS-enabled PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://mgnrega_user:your_password@localhost:5432/mgnrega_verification
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Redis Configuration (Celery broker + caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Copernicus Data Space (Sentinel-2 Satellite Imagery)
# Register at: https://dataspace.copernicus.eu/
# -----------------------------------------------------------------------------
COPERNICUS_CLIENT_ID=your_copernicus_client_id
COPERNICUS_CLIENT_SECRET=your_copernicus_client_secret
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token

# -----------------------------------------------------------------------------
# Sentinel Hub API (Processed Satellite Data & NDVI)
# Register at: https://www.sentinel-hub.com/
# -----------------------------------------------------------------------------
SENTINELHUB_CLIENT_ID=your_sentinelhub_client_id
SENTINELHUB_CLIENT_SECRET=your_sentinelhub_client_secret
SENTINELHUB_BASE_URL=https://services.sentinel-hub.com

# -----------------------------------------------------------------------------
# NREGA Public Data Portal
# -----------------------------------------------------------------------------
NREGA_BASE_URL=https://nrega.nic.in
NREGA_API_TIMEOUT=30
NREGA_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# ISRO Bhuvan Geoportal API
# Register at: https://bhuvan.nrsc.gov.in/
# -----------------------------------------------------------------------------
BHUVAN_API_KEY=your_bhuvan_api_key
BHUVAN_BASE_URL=https://bhuvan-vec2.nrsc.gov.in

# -----------------------------------------------------------------------------
# Local LLM (Ollama - for report generation & NLP analysis)
# Install: https://ollama.ai/
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# -----------------------------------------------------------------------------
# Bhashini API (Indian Language Translation & NLP)
# Register at: https://bhashini.gov.in/
# -----------------------------------------------------------------------------
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_BASE_URL=https://dhruva-api.bhashini.gov.in

# -----------------------------------------------------------------------------
# Application Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-very-long-random-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Celery Task Queue Configuration
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# -----------------------------------------------------------------------------
# Feature Toggles
# -----------------------------------------------------------------------------
ENABLE_SATELLITE_VERIFICATION=true
ENABLE_PAYMENT_ANOMALY_DETECTION=true
ENABLE_MUSTER_ROLL_ANALYSIS=true
ENABLE_PHOTO_VERIFICATION=true
ENABLE_AUTO_INVESTIGATION=false
ENABLE_BHASHINI_TRANSLATION=false
ENABLE_OLLAMA_REPORTS=true

# -----------------------------------------------------------------------------
# Verification Thresholds
# -----------------------------------------------------------------------------
AREA_MISMATCH_THRESHOLD_PERCENT=20.0
NDVI_CHANGE_THRESHOLD=0.15
PAYMENT_ANOMALY_ZSCORE_THRESHOLD=2.5
ATTENDANCE_ANOMALY_THRESHOLD_DAYS=5
GPS_DISTANCE_TOLERANCE_METERS=500.0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/mgnrega_verification.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
